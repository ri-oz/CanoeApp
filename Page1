<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Canoe Trip RSVP</title>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #1a1a2e;
            --text-color: #e94560;
            --highlight: #0f3460;
            --selected: #16213e;
            --border-color: #e94560;
        }

        body {
            background-color: var(--bg-color);
            color: white;
            font-family: 'Press Start 2P', cursive;
            text-align: center;
            padding: 20px;
            line-height: 1.5;
        }

        h1, h2 {
            color: var(--text-color);
            text-shadow: 2px 2px 0px black;
            margin-bottom: 20px;
        }

        h2 { font-size: 1rem; margin-top: 40px; }

        .container {
            max-width: 800px;
            margin: 0 auto;
            border: 4px solid var(--border-color);
            padding: 30px;
            background-color: rgba(0,0,0,0.5);
            box-shadow: 10px 10px 0px black;
        }

        .grid {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        /* Selectable Cards */
        .card {
            border: 3px dashed gray;
            padding: 15px;
            cursor: pointer;
            transition: 0.2s;
            width: 200px;
            background-color: black;
        }

        .card img {
            width: 100%;
            height: 120px;
            object-fit: cover;
            border-bottom: 2px solid gray;
            margin-bottom: 10px;
        }

        .card:hover {
            border-color: white;
            transform: scale(1.05);
        }

        .card.active {
            border: 4px solid #4ecca3;
            background-color: var(--highlight);
            box-shadow: 0 0 15px #4ecca3;
        }

        .card h3 {
            font-size: 0.8rem;
            color: #4ecca3;
        }

        .card p {
            font-size: 0.6rem;
            color: #aaa;
        }

        /* Character Input */
        input[type="text"] {
            font-family: 'Press Start 2P', cursive;
            background: black;
            color: #4ecca3;
            border: 3px solid var(--border-color);
            padding: 15px;
            font-size: 1rem;
            width: 80%;
            max-width: 400px;
            text-align: center;
        }

        input[type="text"]:focus {
            outline: none;
            border-color: #4ecca3;
        }

        /* Submit Button */
        .start-btn {
            margin-top: 50px;
            background-color: var(--text-color);
            color: white;
            font-family: 'Press Start 2P', cursive;
            font-size: 1.2rem;
            padding: 15px 30px;
            border: 4px solid white;
            cursor: pointer;
            box-shadow: 5px 5px 0px black;
            transition: 0.1s;
        }

        .start-btn:hover {
            background-color: #ff2a4b;
            transform: translate(-2px, -2px);
            box-shadow: 7px 7px 0px black;
        }

        .start-btn:active {
            transform: translate(3px, 3px);
            box-shadow: 2px 2px 0px black;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>PLAYER SELECT</h1>
        
        <h2>1. ENTER PLAYER NAME</h2>
        <input type="text" id="playerName" placeholder="e.g. River King" required>

        <h2>2. CHOOSE YOUR VESSEL</h2>
        <div class="grid" id="boatSelection">
            <div class="card boat-card" data-value="Crimson Canoe">
                <img src="kanoe-roto-viking (1).jpg" alt="Red Canoe">
                <h3>Crimson Cruiser</h3>
                <p>Class: Heavy Canoe</p>
                <p>Capacity: 3 Players</p>
                <p>Stat: High Cargo, Low Speed</p>
            </div>
            <div class="card boat-card" data-value="Orange Kayak">
                <img src="kajak-vista.jpg" alt="Orange Kayak">
                <h3>Orange Outlaw</h3>
                <p>Class: Rapid Kayak</p>
                <p>Capacity: 2 Players</p>
                <p>Stat: High Speed, Low Cargo</p>
            </div>
        </div>

        <h2>3. SELECT DIFFICULTY</h2>
        <div class="grid" id="difficultySelection">
            <div class="card diff-card" data-value="Chill">
                <h3>EASY</h3>
                <p>Lazy River Float</p>
                <p>(Snacks included)</p>
            </div>
            <div class="card diff-card" data-value="Moderate">
                <h3>NORMAL</h3>
                <p>Steady Paddling</p>
                <p>(A light workout)</p>
            </div>
            <div class="card diff-card" data-value="Hardcore">
                <h3>HARDCORE</h3>
                <p>White Water Rush</p>
                <p>(Prepare to get wet)</p>
            </div>
        </div>

        <button class="start-btn" onclick="submitRSVP()">JOIN LOBBY</button>
    </div>

    <script>
        // Logic to handle selections
        let selectedBoat = null;
        let selectedDifficulty = null;

        // Function to handle card clicking
        function setupSelection(cardClass, callback) {
            const cards = document.querySelectorAll(cardClass);
            cards.forEach(card => {
                card.addEventListener('click', () => {
                    // Remove active class from all peers
                    cards.forEach(c => c.classList.remove('active'));
                    // Add active class to clicked card
                    card.classList.add('active');
                    // Save the value
                    callback(card.getAttribute('data-value'));
                });
            });
        }

        // Initialize selections
        setupSelection('.boat-card', (val) => selectedBoat = val);
        setupSelection('.diff-card', (val) => selectedDifficulty = val);

        // Submit Function
        function submitRSVP() {
            const playerName = document.getElementById('playerName').value.trim();

            if (!playerName) {
                alert("ERROR: Player Name required!");
                return;
            }
            if (!selectedBoat) {
                alert("ERROR: Please select a vessel!");
                return;
            }
            if (!selectedDifficulty) {
                alert("ERROR: Please select a difficulty level!");
                return;
            }

            // This is where you would send the data to your server/email
            const confirmationMessage = `
                PLAYER: ${playerName}
                VESSEL: ${selectedBoat}
                DIFFICULTY: ${selectedDifficulty}
                
                Lobby joined successfully! See you on the water.
            `;
            
            alert(confirmationMessage);
            // Example of what to do next: window.location.href = "/thank-you-page";
        }
    </script>
</body>
</html>
